{
  "info": {
    "name": "SRI04 - Security JWT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login jako admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set(\"accessToken\", json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@pandas.pl\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login jako user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set(\"accessToken\", json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@pandas.pl\",\n  \"password\": \"user123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login - bledne haslo (401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@pandas.pl\",\n  \"password\": \"zlehaslo\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Patients - publiczne",
      "item": [
        {
          "name": "GET wszyscy pacjenci (bez tokenu)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/patients",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients"]
            }
          }
        }
      ]
    },
    {
      "name": "Patients - wymaga logowania",
      "item": [
        {
          "name": "GET pacjent po ID (z tokenem)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/patients/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients", "1"]
            }
          }
        },
        {
          "name": "GET pacjent po ID (bez tokenu - 401)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/patients/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Patients - tylko ADMIN",
      "item": [
        {
          "name": "POST nowy pacjent (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jan\",\n  \"lastName\": \"Testowy\",\n  \"dateOfBirth\": \"2012-05-20\",\n  \"guardianEmail\": \"opiekun@example.pl\",\n  \"guardianPhone\": \"600000001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/patients",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients"]
            }
          }
        },
        {
          "name": "POST nowy pacjent (user - 403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Anna\",\n  \"lastName\": \"Testowa\",\n  \"dateOfBirth\": \"2014-03-10\",\n  \"guardianEmail\": \"mama@example.pl\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/patients",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients"]
            }
          }
        },
        {
          "name": "PUT aktualizacja pacjenta (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Marek\",\n  \"lastName\": \"Kowalski\",\n  \"dateOfBirth\": \"2015-03-10\",\n  \"guardianEmail\": \"nowy@example.pl\",\n  \"guardianPhone\": \"699000000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/patients/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients", "1"]
            }
          }
        },
        {
          "name": "DELETE pacjent (admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/patients/2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patients", "2"]
            }
          }
        }
      ]
    }
  ]
}
