{
  "info": {
    "name": "SRI-03 — Company & Employee REST API",
    "_postman_id": "sri03-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Companies",
      "item": [
        {
          "name": "GET all companies",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/api/companies",
            "header": [{ "key": "Accept", "value": "application/hal+json" }]
          }
        },
        {
          "name": "GET company by id (with employees)",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/api/companies/1",
            "header": [{ "key": "Accept", "value": "application/hal+json" }]
          }
        },
        {
          "name": "POST create company (valid)",
          "request": {
            "method": "POST",
            "url": "http://localhost:8080/api/companies",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nowa Firma Sp. z o.o.\"\n}"
            }
          }
        },
        {
          "name": "POST create company (INVALID — validation error)",
          "request": {
            "method": "POST",
            "url": "http://localhost:8080/api/companies",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\"\n}"
            }
          }
        },
        {
          "name": "PUT update company",
          "request": {
            "method": "PUT",
            "url": "http://localhost:8080/api/companies/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corporation Updated\"\n}"
            }
          }
        },
        {
          "name": "DELETE company",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:8080/api/companies/3"
          }
        }
      ]
    },
    {
      "name": "Company — Employee Relationships",
      "item": [
        {
          "name": "GET only employees of company (3b)",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/api/companies/1/employees",
            "header": [{ "key": "Accept", "value": "application/hal+json" }]
          }
        },
        {
          "name": "POST add employee to company (3c)",
          "request": {
            "method": "POST",
            "url": "http://localhost:8080/api/companies/2/employees/3"
          }
        },
        {
          "name": "DELETE remove employee from company (3d)",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:8080/api/companies/2/employees/3"
          }
        }
      ]
    },
